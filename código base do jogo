public abstract class Personagem
{
    public string Nome { get; set; }
    public int Vida { get; set; }
    public int Dano { get; set; }
    public int Mana { get; set; }
    public int Cenegia { get; set; }
    
    public List<Condiçoes> ListaCond = new List<Condiçoes>();

    public void AplicarCond(Condiçoes condiçao)
    {
        condiçao.Aoaplicar(this);
        ListaCond.Add(condiçao);
    }

    public void ProcessarCondiçoes()
    {
        for (int i = ListaCond.Count - 1; i >= 0; i--)
        {
            Condiçoes c = ListaCond[i];
            c.Aoturno(this);
            c.turnosrest--;

            if (c.turnosrest <= 0)
            {
                c.Aoexpirar(this);
                ListaCond.RemoveAt(i);
            }

        }
    }
}
abstract class inimigo : Personagem
{
    
    public int CAE { get; set;  }
    public int JogadaATK { get; set; }
    public string aparencia { get; set; }

    public List<ataques> ElistaATK = new List<ataques>();
    
    public abstract void ATKale(classe jogador);

    public abstract void Descricao();
    
}
class Goblin : inimigo
{
    public Goblin()
    {
        Nome = "Goblin";
        Vida = 100;
        Dano = 5;
        Mana = 5;
        Cenegia = 10;
        CAE = 13;
        JogadaATK = Random.Shared.Next(1,20);
        aparencia = " (   0   )   0   ) ";

        ElistaATK.Add(new Eatkfaca());
        ElistaATK.Add(new Eatkcuspe());
        ElistaATK.Add(new Eatkrisada());
        
    }
    public override void ATKale(classe jogador)
    {
        var ataquepossi = ElistaATK
            .Where(h => Cenegia >= h.Cenergia && Mana >= h.Mana)
            .ToList();
        if ( ataquepossi.Count == 0)
        {
            ElistaATK[0].Executar(jogador, this);
            return;
        }

        Random rnd = new Random();
        int atkale = rnd.Next(ataquepossi.Count);
        ataques escolhido = ataquepossi[atkale];
        escolhido.Executar(jogador, this);
        Thread.Sleep(2000);
    }
    public override void Descricao()
    {
        Console.WriteLine("Uma criatura verde feia e nariguda aparece, ele parece esta de olho no seu ouro");
    }
   
    
        
    
}
